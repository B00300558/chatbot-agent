# =============================================================
#  Configuration de l'assistant FAQ ESSEC
#  Copiez ce fichier vers .env puis renseignez vos vraies cles :
#      cp .env.example .env
#  Le fichier .env n'est jamais envoye sur Git (voir .gitignore).
# =============================================================

# ---- Elasticsearch ----
# URL de l'endpoint _search de l'index FAQ
ELK_URL=https://myelk.essec.fr/myessec_faq/_search

# Cle API Elasticsearch. NE JAMAIS committer la vraie cle : elle reste cote serveur.
ELK_API_KEY=colle_ta_cle_elasticsearch_ici

# Mettre a "true" UNIQUEMENT si le serveur ELK a un certificat auto-signe
# et que les appels echouent avec une erreur de certificat TLS.
ELK_INSECURE=false

# Nombre de candidats recuperes dans Elasticsearch avant re-ranking (recall)
CANDIDATES=10

# Nombre d'articles affiches au maximum (moins, voire 0 si rien de pertinent)
MAX_SOURCES=3

# ---- Reponse rediged par IA (RAG via Databricks) ----
# Endpoint Databricks interne ESSEC servant Claude Sonnet 4.5.
# Token d'acces : Databricks -> Settings -> Developer -> Access tokens.
# Si URL ou token manquent, l'app bascule sur la synthese sans IA.
DATABRICKS_URL=https://adb-2262788207842702.2.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-5/invocations
DATABRICKS_TOKEN=colle_ton_token_databricks_ici

# Note minimale (1-5) que le LLM doit s'attribuer pour que sa reponse soit affichee.
SCORE_MIN=3

# Mode sans IA : part minimale (0-1) des mots de la question qui doivent se
# retrouver dans l'article, sinon "Information non trouvee".
SYNTH_MIN_COVERAGE=0.5

# Mettre a "false" pour forcer le mode sans IA meme si le token est present.
RAG_ENABLED=true

# ---- Serveur web ----
PORT=3000
