# ---- Configuration Elasticsearch ----
# URL de l'endpoint _search de l'index FAQ
ELK_URL=https://myelk.essec.fr/myessec_faq/_search

# Cle API Elasticsearch. NE JAMAIS committer la vraie cle : elle reste cote serveur.
ELK_API_KEY=colle_ta_cle_elasticsearch_ici

# Mettre a "true" UNIQUEMENT si le serveur ELK a un certificat auto-signe
# et que les appels echouent avec une erreur de certificat TLS.
ELK_INSECURE=false

# Nombre de candidats recuperes dans Elasticsearch avant re-ranking (recall)
CANDIDATES=10

# Nombre d'articles affiches au maximum (moins, voire 0 si rien de pertinent)
MAX_SOURCES=3

# ---- Reponse rediged par IA (RAG avec Claude / Anthropic) ----
# Cle API Anthropic. Si vide, l'app bascule sur une synthese sans IA.
ANTHROPIC_API_KEY=colle_ta_cle_anthropic_ici

# Modele Claude a utiliser. Rapide/economique par defaut ; pour des reponses
# plus riches, essayez claude-3-5-sonnet-latest.
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Mettre a "false" pour forcer le mode sans IA meme si une cle est presente.
RAG_ENABLED=true

# ---- Serveur web ----
PORT=3000

